# Frontend Environment Variables

# API URL
VITE_REACT_APP_API_URL=api_url

# Razorpay Key (for frontend checkout)
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id

# DigiLocker Gateway (sandbox for development, production for live)
VITE_DIGILOCKER_GATEWAY=production

# WhatsApp Group Links
VITE_WHATSAPP_GROUP_LINK=https://wa.me/YOUR_WHATSAPP_NUMBER_OR_GROUP_LINK
VITE_TECHNICAL_SUPPORT_WHATSAPP_LINK=https://wa.me/YOUR_TECHNICAL_SUPPORT_WHATSAPP_LINK
VITE_SALES_MARKETING_WHATSAPP_LINK=https://wa.me/YOUR_SALES_MARKETING_WHATSAPP_LINK

# Social Media Links
VITE_FACEBOOK_LINK=https://www.facebook.com/yourcompany
VITE_INSTAGRAM_LINK=https://www.instagram.com/yourcompany
VITE_LINKEDIN_LINK=https://www.linkedin.com/company/yourcompany
VITE_TWITTER_LINK=https://twitter.com/yourcompany
VITE_YOUTUBE_LINK=https://www.youtube.com/yourchannel

# Support Contact
VITE_SUPPORT_EMAIL=support@yourcompany.com
VITE_SUPPORT_PHONE=+91 9876543210